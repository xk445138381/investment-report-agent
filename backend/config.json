{
  "version": "1.0",
  "global": {
    "language": "zh-CN",
    "default_market": "auto",
    "data_priority": "local_first",
    "cache_root": "~/.investment_report_agent/cache",
    "max_report_token_budget": 200000
  },
  "llm_providers": {
    "provider_deep": {
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
      "temperature": 0.3,
      "max_tokens": 16000,
      "api_key_source": "env:DEEPSEEK_API_KEY",
      "timeout_seconds": 180,
      "note": "DeepSeek V4 Pro — 深度分析、辩论、报告撰写"
    },
    "provider_quick": {
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
      "temperature": 0.3,
      "max_tokens": 8000,
      "api_key_source": "env:DEEPSEEK_API_KEY",
      "timeout_seconds": 60,
      "note": "DeepSeek V4 Pro — 数据聚合、摘要、图表"
    },
    "provider_heavy": {
      "provider": "openai",
      "model": "gpt-4o",
      "temperature": 0.4,
      "max_tokens": 8000,
      "api_key_source": "env:OPENAI_API_KEY",
      "timeout_seconds": 120,
      "note": "GPT-4o — 段永平/芒格视角评估（重度推理）"
    },
    "provider_heavy_claude": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "temperature": 0.4,
      "max_tokens": 8000,
      "api_key_source": "env:ANTHROPIC_API_KEY",
      "timeout_seconds": 120,
      "note": "Claude Sonnet 4.6 — 段永平/芒格视角评估备选"
    }
  },
  "pipelines": {
    "quick_scan": {
      "name": "快速扫描（技术面+资金面+一句话总结）",
      "phases": {
        "phase_1": {
          "parallel": true,
          "agents": ["price_data", "financial_data", "tech_indicators", "fund_flow", "news_data"]
        },
        "phase_2": {
          "parallel": false,
          "agents": ["quick_summary"],
          "debate_rounds": 1
        }
      }
    },
    "value_deep_dive": {
      "name": "价值投资研报（段永平+芒格双视角）",
      "phases": {
        "phase_1": {
          "parallel": true,
          "agents": ["price_data", "financial_data", "news_data", "macro_data"]
        },
        "phase_2": {
          "parallel": true,
          "agents": ["financial_analysis", "valuation", "industry_competition", "corporate_governance"]
        },
        "phase_3": {
          "parallel": true,
          "agents": ["duan_case", "munger_case"],
          "debate_rounds": 1
        },
        "phase_3b": {
          "parallel": false,
          "agents": ["value_judge"],
          "debate_rounds": 1
        },
        "phase_4": {
          "parallel": false,
          "agents": ["section_writer", "chart_generator", "title_summary"],
          "export": ["pdf"]
        }
      }
    },
    "deep_dive": {
      "name": "深度研报",
      "phases": {
        "phase_1": {
          "parallel": true,
          "agents": ["price_data", "financial_data", "news_data", "macro_data"]
        },
        "phase_2": {
          "parallel": true,
          "agents": ["financial_analysis", "valuation", "industry_competition", "corporate_governance"]
        },
        "phase_3": {
          "parallel": false,
          "agents": ["bull_case", "bear_case", "risk_judge"],
          "debate_rounds": 2
        },
        "phase_4": {
          "parallel": false,
          "agents": ["section_writer", "chart_generator", "title_summary"],
          "export": ["pdf"]
        }
      }
    },
    "brief": {
      "name": "快速简报",
      "phases": {
        "phase_1": {
          "parallel": true,
          "agents": ["price_data", "financial_data", "news_data"]
        },
        "phase_2": {
          "parallel": true,
          "agents": ["financial_analysis", "valuation"]
        },
        "phase_3": {
          "parallel": false,
          "agents": ["bull_case", "bear_case", "risk_judge"],
          "debate_rounds": 1
        },
        "phase_4": {
          "parallel": false,
          "agents": ["section_writer", "title_summary"],
          "export": ["pdf"]
        }
      }
    }
  },
  "agents": {
    "price_data": {"llm": "provider_quick", "output_schema": "PriceDataResult", "timeout_seconds": 60},
    "financial_data": {"llm": "provider_quick", "output_schema": "FinancialDataResult", "timeout_seconds": 60},
    "news_data": {"llm": "provider_quick", "tools": ["get_recent_news"], "output_schema": "NewsAggregation", "timeout_seconds": 60},
    "macro_data": {"llm": "provider_quick", "output_schema": "MacroDataResult", "timeout_seconds": 60},
    "financial_analysis": {"llm": "provider_deep", "python_calculator": "financial_health_calculator", "output_schema": "FinancialHealthResult", "timeout_seconds": 120},
    "valuation": {"llm": "provider_deep", "python_calculator": "valuation_engine", "output_schema": "ValuationResult", "timeout_seconds": 180},
    "industry_competition": {"llm": "provider_deep", "output_schema": "IndustryCompetitionResult", "timeout_seconds": 120},
    "corporate_governance": {"llm": "provider_deep", "output_schema": "GovernanceResult", "timeout_seconds": 120},
    "bull_case": {"llm": "provider_deep", "tools": ["query_additional_data"], "output_schema": "DebateArguments", "timeout_seconds": 25},
    "bear_case": {"llm": "provider_deep", "tools": ["query_additional_data"], "output_schema": "DebateArguments", "timeout_seconds": 25},
    "risk_judge": {"llm": "provider_deep", "output_schema": "RiskJudgeResult", "timeout_seconds": 25},
    "duan_case": {"llm": "provider_deep", "output_schema": "ValuePerspectiveResult", "timeout_seconds": 300, "note": "段永平视角：商业模式+本分+现金流确定性"},
    "munger_case": {"llm": "provider_deep", "output_schema": "ValuePerspectiveResult", "timeout_seconds": 300, "note": "芒格视角：逆向+Lollapalooza+激励诊断"},
    "value_judge": {"llm": "provider_deep", "output_schema": "ValueJudgeResult", "timeout_seconds": 300, "note": "双视角裁决：共识/分歧/Yes-No-Too Hard"},
    "section_writer": {"llm": "provider_deep", "output_schema": "ReportSections", "timeout_seconds": 300},
    "chart_generator": {"llm": "provider_quick", "output_schema": "ChartOutputs", "timeout_seconds": 60},
    "title_summary": {"llm": "provider_quick", "output_schema": "ReportMetadata", "timeout_seconds": 30},
    "tech_indicators": {"llm": "provider_quick", "output_schema": "TechIndicatorResult", "timeout_seconds": 30, "note": "技术指标：MA/MACD/RSI"},
    "fund_flow": {"llm": "provider_quick", "output_schema": "FundFlowResult", "timeout_seconds": 30, "note": "资金面：主力+北向"},
    "quick_summary": {"llm": "provider_deep", "output_schema": "QuickSummaryResult", "timeout_seconds": 60, "note": "一句话LLM总结"}
  },
  "logging": {
    "level": "INFO",
    "output": ["console", "file"],
    "file_path": "~/.investment_report_agent/logs/agent.log"
  }
}
