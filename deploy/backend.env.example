# Copy to backend/.env before running docker compose for production rehearsal.
# Store real production values in the hosting platform secret manager.

SECRET_KEY=replace-with-strong-random-secret
DEEPSEEK_API_KEY=replace-with-real-deepseek-api-key
QVERIS_API_KEY=replace-with-real-qveris-api-key

ENVIRONMENT=production
ENABLE_DEBUG_ROUTES=false
ENABLE_RUNTIME_CONFIG_WRITES=false
REQUIRE_MONGODB=true
REQUIRED_ENV_VARS=SECRET_KEY,DEEPSEEK_API_KEY,QVERIS_API_KEY

FRONTEND_ORIGINS=https://app.example.com
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_DATABASE=tradingagents
LOG_LEVEL=INFO
